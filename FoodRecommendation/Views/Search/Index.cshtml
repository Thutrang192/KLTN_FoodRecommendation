@model IEnumerable<FoodRecommendation.Models.Entity.Recipe>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
    var favorite = ViewBag.Favorite as Dictionary<int, int>;
    var rating = ViewBag.Rating as Dictionary<int, double>;
}

<h2 class="mb-3" style="margin-top: 20px;">🍽 Kết quả gợi ý món ăn</h2>

<!-- 🔍 SEARCH BAR -->
<form method="get" action="/Search" class="mb-4">
    <input type="hidden" name="sort" value="@Context.Request.Query["sort"]" />

    <div class="input-group search-box">
        <input type="text"
               name="query"
               value="@ViewBag.Query"
               class="form-control search-input"
               placeholder="Nhập món ăn hoặc nguyên liệu..." />

        <button class="btn btn-search-orange" type="submit">
            Tìm kiếm
        </button>
    </div>
</form>

<!-- SORT BUTTONS -->
<div class="d-flex justify-content-between align-items-center mb-3">

    <h5>Danh sách món ăn</h5>

    <div>
        <a href="/Search?query=@ViewBag.Query&sort=favorite"
           class="btn btn-outline-danger me-2"
           data-bs-toggle="tooltip"
           data-bs-placement="top"
           title="Sắp xếp theo số lượt yêu thích (giảm dần)">
            ❤️ Yêu thích
        </a>

        <a href="/Search?query=@ViewBag.Query&sort=rating"
           class="btn btn-outline-warning"
           data-bs-toggle="tooltip"
           data-bs-placement="top"
           title="Sắp xếp theo điểm đánh giá (giảm dần)">
            ⭐ Đánh giá
        </a>
    </div>

</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        Không tìm thấy món ăn phù hợp.
    </div>
}
else
{
    @foreach (var item in Model)
    {
        <a href="/Home/Detail/@item.RecipeId"
           class="text-decoration-none text-dark">

            <div class="card mb-3 shadow-sm recipe-card">

                <div class="row g-0">

                    <!-- IMAGE -->
                    <div class="col-md-3">
                        <img src="@item.ImageUrl"
                             class="img-fluid rounded-start"
                             style="height:180px; width:100%; object-fit:cover;">
                    </div>

                    <!-- CONTENT -->
                    <div class="col-md-9">
                        <div class="card-body">

                            <h5 class="card-title fw-bold">
                                @item.Title
                            </h5>

                            <p class="card-text text-muted">
                                @item.DescriptionRecipes
                            </p>

                            <div class="d-flex flex-wrap gap-3 text-muted">

                                <span>⏱ @item.Cooktime</span>

                                <span>🍽 @item.Serving</span>

                                <span>👤 @item.User?.Username</span>

                                <span class="text-danger">
                                    ❤️ @(favorite?.GetValueOrDefault(item.RecipeId, 0) ?? 0)
                                </span>

                                <span class="text-warning">
                                    ⭐ @((rating?.GetValueOrDefault(item.RecipeId, 0) ?? 0).ToString("F1"))
                                </span>

                            </div>

                        </div>
                    </div>

                </div>

            </div>

        </a>
    }
}

<style>
.recipe-card {
    cursor: pointer;
    transition: 0.2s;
}

.recipe-card:hover {
    transform: scale(1.02);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}

/* Tooltip custom */
.tooltip-inner {
    background: linear-gradient(135deg, #ff7a00, #ff9a3c);
    color: white;
    border-radius: 8px;
    padding: 6px 12px;
    font-weight: 500;
}

.tooltip.bs-tooltip-top .tooltip-arrow::before {
    border-top-color: #ff7a00;
}

.tooltip.bs-tooltip-bottom .tooltip-arrow::before {
    border-bottom-color: #ff7a00;
}

.tooltip.bs-tooltip-start .tooltip-arrow::before {
    border-left-color: #ff7a00;
}

.tooltip.bs-tooltip-end .tooltip-arrow::before {
    border-right-color: #ff7a00;
}

.search-box {
    border-radius: 50px;
    overflow: hidden; /* quan trọng để bo tròn cả cụm */
    box-shadow: 0 3px 10px rgba(0,0,0,0.08);
}

/* Ô input */
.search-input {
    border: none;
    padding: 12px 18px;
    font-size: 15px;
    outline: none;
}

/* Khi focus input */
.search-input:focus {
    box-shadow: none;
}

/* Button màu cam */
.btn-search-orange {
    background: linear-gradient(135deg, #ff7a00, #ff9a3c);
    color: white;
    border: none;
    padding: 12px 22px;
    font-weight: 600;
    transition: 0.2s;
}

/* Hover button */
.btn-search-orange:hover {
    background: linear-gradient(135deg, #ff9a3c, #ff7a00);
    transform: scale(1.03);
    color: white;
}
</style>