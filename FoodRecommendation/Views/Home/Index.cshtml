@using FoodRecommendation.Models.Model;
@model IEnumerable<RecipeModel>

@{
    ViewData["Title"] = "Trang Chủ";
}

@{
    Layout = "_Layout";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="row justify-content-center mt-5">
   <div class="col-md-8">
       <form action="/Search" method="get" class="d-flex gap-0 2">
            <div class="input-group search-box flex-nowrap shadow-sm">
               <span class="input-group-text bg-white ps-3">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
               </span>
                <input type="text"
                       name="query"
                       class="form-control border-start-0 rounded-end-pill py-2 shadow-none"
                       placeholder="Vui lòng nhập danh sách nguyên liệu, cách nhau bằng dấu phẩy!">
           </div>

            <button type="submit" class="btn fw-bold px-4 rounded-pill text-white text-nowrap btn-orange ms-3">
                Tìm kiếm
            </button>
       </form>
   </div>

   <div>
        @* <div class="mt-5 mb-2 ps-2">
            <a href="https://docs.google.com/forms/d/1E7YDHqatlInC_miEzJjifKp05Wdg5TQSja-n368knlk"
            style="
                    display: inline-flex;
                    align-items: center;
                    gap: 6px;
                    color: #ff7a00;
                    font-weight: 500;
                    text-decoration: none;
                    padding: 6px 10px;
                    border-radius: 6px;
                    transition: all 0.2s ease;
            "
            onmouseover="this.style.background='#fff3e6'; this.style.color='#e66900'"
            onmouseout="this.style.background='transparent'; this.style.color='#ff7a00'">

                <i class="fa-solid fa-arrow-left"></i>
                Quay lại form đánh giá
            </a>
        </div> *@
       <div class="text-secondary mt-5 mb-2 ps-2">Món ăn nổi bật</div>
        
       <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4 p-2">
           @foreach (var item in Model)
           {
                <div class="col">
                    <a asp-controller="Home"
                       asp-action="Detail"
                       asp-route-id="@item.RecipeId"
                       class="text-decoration-none">

                        <div class="card h-100 border-0 shadow-sm">
                            <div class="ratio ratio-1x1 bg-light position-relative overflow-hidden">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/default-recipe.jpg" : item.ImageUrl)"
                                     class="card-img-top object-fit-cover"
                                     alt="@item.Title"
                                     onerror="this.src='/img/default-recipe.png';">
                            </div>

                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold text-dark mb-2 multiline-ellipsis">@item.Title</h6>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="text-muted small d-flex align-items-center">
                                        <i class="fa-solid fa-square me-2" style="font-size: 8px; color: #dee2e6;"></i>
                                        <span class="text-truncate" style="max-width: 100px;">
                                            @(string.Equals(item.RoleUser, "Admin", StringComparison.OrdinalIgnoreCase) ? "Chef" : item.UserName)
                                        </span>
                                    </div>
                                    @if (item.Cooktime > 0)
                                    {
                                        <span class="text-muted small">
                                            @{
                                                var totalMinutes = (double)(item.Cooktime ?? 0);
                                                var time = TimeSpan.FromMinutes(totalMinutes);

                                                var display = time.TotalHours >= 1
                                                ? $"{(int)time.TotalHours}h" + (time.Minutes > 0 ? $" {time.Minutes}p" : "")
                                                : $"{time.Minutes} phút";
                                            }
                                            <i class="fa-regular fa-clock me-1"></i>@display
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
           }
       </div>

        <!-- PAGINATION -->
        <div class="pagination">
            <a asp-action="Index" asp-route-page="1">«</a>

            <a asp-action="Index"
               asp-route-page="@(ViewBag.CurrentPage > 1 ? ViewBag.CurrentPage - 1 : 1)">
                ‹
            </a>

            <div class="page-info">
                Trang @(ViewBag.CurrentPage ?? 1) / @(ViewBag.TotalPages ?? 1)
            </div>

            <a asp-action="Index"
               asp-route-page="@(ViewBag.CurrentPage < ViewBag.TotalPages ? ViewBag.CurrentPage + 1 : ViewBag.TotalPages)">
                ›
            </a>

            <a asp-action="Index" asp-route-page="@ViewBag.TotalPages">»</a>
        </div>

   </div>
   <div>

   </div>

</div>

