@using FoodRecommendation.Models.Model;
@model IEnumerable<NotiModel>

@{
    ViewData["Title"] = "Thông báo của tôi";
    Layout = "_Layout";
}

<div class="mt-2">
    <h1 class="mt-5 text-custom text-center mb-3">THÔNG BÁO CỦA TÔI (@Model.Count())</h1>
    
    <div class="notification-list ms-5 me-5 ps-5 pe-5">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 shadow-sm bg-white rounded-3">
                <img src="/img/no-notification.png" style="width: 150px; opacity: 0.5" />
                <p class="text-muted mt-3">Bạn chưa có thông báo nào</p>
            </div>
        }
        else
        {
            <div class="ps-5 pe-5">
                @foreach (var item in Model)
                {
                    <div class="noti-item shadow-sm border-0 mb-3 bg-white p-3 rounded-3 d-flex align-items-center position-relative border-start border-4 border-warning">

                        <div class="flex-shrink-0">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/default-recipe.jpeg" : item.ImageUrl)"
                                 class="rounded-2 object-fit-cover"
                                 style="width: 70px; height: 70px;"
                                 alt="@item.Title">
                        </div>

                        <div class="flex-grow-1 ms-3">
                            <div class="d-flex justify-content-between">
                                <h6 class="mb-1 fw-bold text-dark">@item.Title</h6>
                                <small class="text-muted">@item.FormattedCreatedAt</small>
                            </div>
                            <p class="mb-0 small">
                                @item.Content
                            </p>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>


</div>
