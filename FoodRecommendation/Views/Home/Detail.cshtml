@model FoodRecommendation.Models.Model.RecipeModel;
@using System.Net 
@{
    ViewData["Title"] = "Chi tiết món ăn";
}

@{
    Layout = "_Layout";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <script>
        $(document).ready(function () {
            var currentRecipeId = @Model.RecipeId;
            console.log("1. Bắt đầu gọi Ajax cho RecipeId:", currentRecipeId);

            $.ajax({
                url: '/Home/GetRelatedRecipe',
                type: 'GET',
                data: {id: currentRecipeId},
                success: function (data) {
                console.log("2. Kết nối C# thành công. Dữ liệu nhận được:", data);
                $('#related-recipes-container').html(data);
            },
                error: function (xhr, status, error) {
                console.error("2. Lỗi Ajax!");
                console.error("Trạng thái:", status);
                console.error("Nội dung lỗi:", xhr.responseText);
                $('#related-recipes-container').html('<p class="text-danger">Lỗi Ajax: ' + error + '</p>');
                }
            });
        });

        function saveRecipe(id) {
            fetch('/Collection/Toggle', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'recipeId=' + id
            })
            .then(res => res.json())
            .then(data => {

                const btn = document.getElementById("saveBtn");

                if (data.isSaved) {
                    btn.classList.remove("btn-outline-orange");
                    btn.classList.add("btn-orange");

                    btn.innerHTML = '<i class="fa-solid fa-bookmark"></i> Đã lưu';
                }
                else {
                    btn.classList.remove("btn-orange");
                    btn.classList.add("btn-outline-orange");

                    btn.innerHTML = '<i class="fa-regular fa-bookmark"></i> Lưu';
                }

                btn.disabled = false; // luôn cho click lại
            });
        }
    </script>

}

<div class="ms-0 me-5">
    <div class="row mb-5 mt-4">
        <div class="col-12 col-md-3">
            <div class="ratio shadow-sm rounded overflow-hidden object-fit-cover" style="--bs-aspect-ratio: 114.28%">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/img/default-recipe.jpeg" : Model.ImageUrl)"
                alt="Recipe-Picture"
                class="object-fit-cover"
                onerror="this.onerror=null; this.src='/img/default-recipe.jpeg';">
            </div>
        </div>

        <div class="col-12 col-md-9 d-flex flex-column">
            <h2 class="fw-bold m-0">@Model.Title</h2>

            <div class="d-flex align-items-center mt-4">
                <div class="rounded-circle overflow-hidden me-2 flex-shrink-0 border border-1 border-secondary shadow-sm"
                style="width: 35px; height: 35px; background-color: #e2e8f0;">
                    <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "/img/user-icon.png" : Model.AvatarUrl)"
                    alt="Avatar"
                    class="w-100 h-100 object-fit-cover"
                    onerror="this.src='/img/user-icon.png';">
                </div>

                @* <div style="color: red; font-size: 10px;"> *@
                @*     DEBUG: RoleUser = "@Model.RoleUser" | IsAdmin = @string.Equals(Model.RoleUser, "Admin", StringComparison.OrdinalIgnoreCase) *@
                @* </div> *@

                <span class="font-medium text-dark ms-2">
                    @(string.Equals(Model.RoleUser, "Admin", StringComparison.OrdinalIgnoreCase) ? "Chef" : Model.UserName)
                </span>
                
            </div>

            @* <p class="italic text-gray-600 border-l-4 border-gray-200 pl-4 mb-6 mt-3">@Model.DescriptionRecipes</p> *@

            <div class="d-flex gap-3 mt-auto">
                
                <!-- SAVE BUTTON -->
                @if(User.Identity.IsAuthenticated)
                {
                    <button id="saveBtn"
                            onclick="saveRecipe(@Model.RecipeId)"
                            class="btn @(Model.IsSaved ? "btn-orange" : "btn-outline-orange")">

                        <i class="@(Model.IsSaved ? "fa-solid" : "fa-regular") fa-bookmark"></i>

                        @(Model.IsSaved ? "Đã lưu" : "Lưu")
                    </button>
                }
                else {
                    <button class="btn btn-outline-orange"
                            data-bs-toggle="modal"
                            data-bs-target="#loginModal">
                        <i class="fa-regular fa-bookmark"></i> Lưu
                    </button>
                }

                <!-- REPORT BUTTON -->
                <div id="report-container">
                    @if (Model.IsReported)
                    {
                        <button class="px-4 py-2 flex items-center gap-2 btn btn-outline-orange fw-medium" disabled title="Bạn đã báo cáo món này">
                            <i class="fa-solid fa-flag"></i> Đã báo cáo món
                        </button>
                    }
                    else if (User.Identity.IsAuthenticated)
                    {
                        <button id="btn-report-trigger"
                                class="px-4 py-2 btn btn-outline-orange fw-medium"
                                data-recipe-id="@Model.RecipeId"
                                data-logged-in="true"
                                data-bs-toggle="modal"
                                data-bs-target="#reportModal">

                            <i class="fa-regular fa-flag"></i> Báo cáo món
                        </button>
                    }
                    else 
                    {
                        <button 
                                class="px-4 py-2 btn btn-outline-orange fw-medium"
                                data-recipe-id="@Model.RecipeId"
                                data-logged-in="false"
                                data-bs-toggle="modal"
                                data-bs-target="#loginModal">
                            <i class="fa-regular fa-flag"></i> Báo cáo món
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-uppercase fw-bold"><i class="fa-solid fa-utensils me-2"></i> Nguyên liệu</h5>

                <span class="text-muted">
                    <i class="fa-regular fa-user me-1"></i>@Model.Serving
                </span>
            </div>

            <div class="mt-3 card">
                <ul class="list-group list-group-flush">
                    @foreach (var item in Model.Ingredients)
                    {
                        <li class="list-group-item d-flex align-items-center">
                            <span class="me-1">@item.Quantity</span>
                            <span>@item.IngredientsText</span>
                        </li>
                    }

                </ul>
            </div>
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4 mt-4 mt-md-0">
                <h5 class="mb-0 text-uppercase fw-bold mb-0">Các bước thực hiện</h5>
                <span class="text-muted">
                    @if (Model.Cooktime > 0)
                    {
                        var totalMinutes = (double)(Model.Cooktime ?? 0);
                        var time = TimeSpan.FromMinutes(totalMinutes);

                        var display = time.TotalHours >= 1
                        ? $"{(int)time.TotalHours}h" + (time.Minutes > 0 ? $" {time.Minutes}p" : "")
                        : $"{time.Minutes} phút";
                        
                        <i class="fa-regular fa-clock me-1"></i>@display
                    }
                    
                </span>


            </div>

            <div class="row">
                @foreach (var item in Model.Steps)
                {
                    <div class="d-flex mb-4">
                        <div class="flex-shrink-0">
                            <div class="d-flex align-items-center justify-content-center rounded-circle bg-orange text-white shadow-sm"
                            style="width: 40px; height: 40px;">
                                @item.StepNumber
                            </div>
                        </div>

                        <div class="flex-grow-1 ms-3">
                            <p class="mb-3">@item.StepText</p>
                            <div class="row">
                                @foreach (var i in item.ImgUrl)
                                {
                                    <div class="col-3 pe-0">
                                        <div class="ratio ratio-5x4 rounded overflow-hidden">
                                            <img src="@i"
                                            class="w-100 h-100 object-fit-cover"
                                            onerror="this.src='/img/default-recipe.jpeg';" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <hr>


    <!--  RATING -->
    <div class="mb-5">
        <h5 class="fw-bold mb-4">Bình luận (@Model.Ratings.Count())</h5>
            @if (User.Identity.IsAuthenticated)
            {
                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="rounded-circle bg-light border me-3 overflow-hidden"
                             style="width: 40px; height: 40px;">
                            <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "/img/user-icon.png" : Model.AvatarUrl)"
                                 alt="Avatar"
                                 class="w-100 h-100 object-fit-cover"
                                 onerror="this.src='/img/user-icon.png';">
                        </div>
                    </div>

                <div class="flex-grow-1 ms-1">
                    <div id="ratingError" class="text-danger small mb-1 d-none">Vui lòng chọn sao đánh giá!</div>

                    <div class="star-rating mb-2" style="cursor: pointer; color: #ffc107;">
                        <i class="fa-regular fa-star star-item" data-index="1"></i>
                        <i class="fa-regular fa-star star-item" data-index="2"></i>
                        <i class="fa-regular fa-star star-item" data-index="3"></i>
                        <i class="fa-regular fa-star star-item" data-index="4"></i>
                        <i class="fa-regular fa-star star-item" data-index="5"></i>
                    </div>

                    <form asp-controller="Home" asp-action="AddComment" method="post" id="cmtForm">
                        @Html.AntiForgeryToken()
                        <div class="input-group">
                            <input type="hidden" name="RatingValue" id="RatingValue" value="0" />
                            <input type="hidden" name="RecipeId" value="@Model.RecipeId" />

                            <input type="text"
                                   name="Comment"
                                   id="CommentInput"
                                   class="form-control rounded-pill py-2 shadow-none comment-input"
                                   placeholder="Thêm bình luận...">
                            <button type="submit" class="btn btn-link text-muted">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </div>
                        <div id="commentError" class="text-danger small mt-1 d-none">Vui lòng nhập nội dung bình luận!</div>
                    </form>
                </div>
                </div>
            }
            else
            {
                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="rounded-circle bg-light border me-3 d-flex align-items-center justify-content-center"
                                style="width: 40px; height: 40px;">
                            <i class="fa-solid fa-user text-muted"></i>
                        </div>
                    </div>

                    <div class="flex-grow-1">
                        <div class="d-flex">

                        <input type="text"
                               readonly
                               class="form-control rounded-pill py-2 shadow-none comment-input bg-white"
                               placeholder="Thêm bình luận"
                               data-bs-toggle="modal"
                               data-bs-target="#loginModal"
                               style="cursor: pointer;">

                            <button class="btn btn-link text-muted"><i class="fa-solid fa-paper-plane"></i></button>
                        </div>
                    </div>
                </div>
            }

            @foreach(var r in Model.Ratings)
            {
                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="rounded-circle bg-light border me-3 overflow-hidden"
                             style="width: 40px; height: 40px;">
                        <img src="@(string.IsNullOrEmpty(r.AvatarUrl) ? "/img/user-icon.png" : r.AvatarUrl)"
                                 alt="Avatar"
                                 class="w-100 h-100 object-fit-cover"
                                 onerror="this.src='/img/user-icon.png';">
                        </div>
                    </div>

                    <div class="flex-grow-1">
                        <div>
                            <b class="small">@r.UserName</b>
                            <small class="text-muted" style="font-size: 12px;">@r.FormattedCreatedAt</small>
                        </div>
                        <div class="text-warning">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= r.Score)
                                {
                                    <i class="fa-solid fa-star"></i>
                                }
                                else
                                {
                                    <i class="fa-regular fa-star"></i>
                                }
                            }
                        </div>
                        <p class="mb-0 small">@r.Comment</p>
                    </div>
                </div>
            }
    </div>

    <h5 class="fw-bold mb-4">Có thể bạn cũng thích</h5>
    <div id="related-recipes-container">
        <p class="text-muted small italic">Đang tìm kiếm món ăn tương tự...</p>
    </div>
  
</div>

<!--  MODAL REPORT -->
<div class="modal fade" id="reportModal" tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-center w-100" id="reportModalLabel">
                    <i class="fa-solid fa-triangle-exclamation text-danger"></i> Báo cáo món ăn
                </h5>
            </div>

            <div class="modal-body">
                <p class="text-muted small">Vui lòng cho chúng tôi biết vấn đề bạn gặp phải với món ăn này.</p>

                <div class="mb-3">
                    <div id="reportOptions">
                        <div class="form-check mb-2">
                            <input class="form-check-input report-checkbox" type="checkbox" value="Nội dung hình ảnh phản cảm" id="reason1">
                            <label class="form-check-label" for="reason1">Nội dung hình ảnh phản cảm</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input report-checkbox" type="checkbox" value="Công thức sai lệch/Không thực tế" id="reason2">
                            <label class="form-check-label" for="reason2">Công thức sai lệch/Không thực tế</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input report-checkbox" type="checkbox" value="Ngôn từ thù địch, kích động" id="reason3">
                            <label class="form-check-label" for="reason3">Ngôn từ thù địch, kích động</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input report-checkbox" type="checkbox" value="Lý do khác" id="reasonOther">
                            <label class="form-check-label" for="reasonOther">Lý do khác...</label>
                        </div>

                        <textarea class="form-control mt-2 d-none" id="otherReasonText" rows="2" placeholder="Nhập chi tiết lý do khác..."></textarea>
                    </div>

                    <div id="reportError" class="text-danger small mt-2 d-none">Vui lòng chọn một lý do để gửi báo cáo.</div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" id="btnSendReport" class="btn bg-orange px-4">
                    Gửi báo cáo
                </button>
            </div>
        </div>

    </div>
</div>

<!-- MODAL LOGIN -->
<div class="modal fade" id="loginModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Yêu cầu đăng nhập</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <p>Bạn cần đăng nhập để thực hiện chức năng này!</p>
            </div>

            <div class="modal-footer justify-content-center">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <a href="/Account/Login?returnUrl=@WebUtility.UrlEncode(Context.Request.Path + Context.Request.QueryString)" class="btn bg-orange">
                    Đăng nhập
                </a>
            </div>

        </div>
    </div>
</div>
