@using FoodRecommendation.Models.Model
@model AccountModel
@using FoodRecommendation.Constant

@{
	Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Đăng Nhập</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

	<link href="~/img/favicon.png" rel="icon" />
	<link href="~/assets/css/all.min.css" rel="stylesheet" />

</head>

<body class="container-fluid mb-0">
	<div class="row">
		<div class="col-md-6 p-5 pb-0">
			
			<div class="m-5">
				<h1 class="text-gray-900 mb-6">Bắt đầu nấu thôi!</h1>
				<h5 class="text-gray-300 font-normal mt-2">Đăng nhập để khám phá công thức nấu ăn thông minh dựa trên nguyên liệu bạn đang có.</h5>
			</div>

			<form method="post" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
				<div asp-validation-summary="ModelOnly" class="text-danger mb-3 ps-5 pe-5"></div>
				<div class="mb-0 ps-5 pe-5">
					<label class="form-label">Email</label>
					<div class="input-group">
						<span class="input-group-text text-custom" style="background: transparent; border-right: none">
							<i class="fa fa-envelope"></i>
						</span>
						<input asp-for="Email" type="email" class="form-control" placeholder="Nhập email" style="border-left: none;">
					</div>
					<div class="validation-message-wrapper">
						@Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
					</div>
				</div>

				<div class="mb-0 ps-5 pe-5">
					<label class="form-label">Mật khẩu</label>
					<div class="input-group">
						<span class="input-group-text text-custom" style="background: transparent; border-right: none;">
							<i class="fa fa-lock"></i>
						</span>
						<input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" style="border-left: none;">
					</div>
					<div class="validation-message-wrapper">
						@Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
					</div>
				</div>

				<div class="ps-5 pe-5 mt-3">
					<button type="submit" class="btn-orange w-100 p-2 rounded">Đăng nhập</button>
				</div>
			</form>

			<p class="text-center mt-3">
				Bạn chưa có tài khoản?
				<a asp-controller="Account" asp-action="Register" class="text-custom">
					Đăng ký ngay
				</a>
			</p>
		</div>

		<div class="col-md-6 px-0 d-none d-md-block" style="height: 100vh; overflow: hidden;">
			<img src="/img/bg2.png"
				 alt="Background"
				 class="img-fluid"
				 style="width: 100%; height: 100%; object-fit: cover; display: block;" />
		</div>

		<div class="bs-toast toast toast-placement @(ViewBag.ToastType?.ToString() == Constants.Success ? "bg-success" : "bg-danger") top-0 end-0 mr-3 mt-3"
			 role="alert"
			 aria-live="assertive"
			 aria-atomic="true"
			 data-delay="3000">
			<div class="toast-header">
				<i class="bx bx-bell mr-2"></i>
				<div class="me-auto fw-semibold">@(ViewBag.ToastType?.ToString() == Constants.Success ? "Thành công" : "Thất bại")</div>
			</div>
			<div class="toast-body">
				@ViewBag.ToastMessage
			</div>
		</div>
	</div>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
	<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

	<script type="text/javascript">
		$(document).ready(function () {
			// Kiểm tra nếu có toast message trong TempData
			if ('@ViewBag.ToastType' && '@ViewBag.ToastType' != 'None') {
				// Hiển thị toast message
				$('.toast-placement').toast('show');
			}
		});
	</script>
	@{
		ViewBag.ToastType = Constants.None;
		ViewBag.ToastMessage = string.Empty;
	}
</body>

</html>