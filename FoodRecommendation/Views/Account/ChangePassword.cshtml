@using FoodRecommendation.Models.Entity
@using Newtonsoft.Json;
@using Microsoft.AspNetCore.Http;
@using FoodRecommendation.Constant;
@using System.Security.Claims
@model ChangePasswordVM


@{
    Layout = "_Layout";
}

@{
    ViewData["Title"] = "Thay đổi mật khẩu";
}

<link rel="stylesheet" href="~/css/changepassword.css" asp-append-version="true" />
   
            <!-- MAIN BODY -->
<div class="password-container my-5">
    <div class="password-header">
        <h2><i class="fas fa-lock"></i> Đổi mật khẩu</h2>
        <p>Cập nhật mật khẩu để bảo vệ tài khoản của bạn</p>
    </div>

    <div class="password-card">
        <h3 class="section-title"><i class="fas fa-shield-alt"></i> Bảo mật mật khẩu</h3>
        <hr class="divider" />

     @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }
    <form id="changePasswordForm"
          asp-controller="Account"
          asp-action="ChangePassword"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- CURRENT PASSWORD -->
        <div class="form-group">
            <label>Mật khẩu hiện tại *</label>
            <div class="input-wrapper">
                <input asp-for="CurrentPassword" autocomplete="new-password" class="form-control" placeholder="Mật khẩu hiện tại" />
           
                <i class="far fa-eye toggle-password"></i>
            </div>
             <span asp-validation-for="CurrentPassword" class="text-danger"></span>
        </div>

        <!-- NEW PASSWORD -->
        <div class="form-group">
            <label>Mật khẩu mới *</label>
            <div class="input-wrapper">
                <input asp-for="NewPassword" autocomplete="new-password" type="password" class="form-control" placeholder="Mật khẩu mới" />
          
                <i class="far fa-eye toggle-password"></i>
            </div>
              <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>

        <p class="password-hint">
            <i class="fas fa-info-circle"></i>
            Mật khẩu phải có ít nhất 8 ký tự, bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt
        </p>

        <!-- CONFIRM PASSWORD -->
        <div class="form-group">
            <label>Xác nhận mật khẩu mới *</label>
            <div class="input-wrapper">
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Xác nhận mật khẩu mới" />
            
                <i class="far fa-eye toggle-password"></i>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
    </form>

</div>

<div class="form-actions">
    <button type="submit" form="changePasswordForm" class="btn-change">
        <i class="fas fa-save"></i> Đổi mật khẩu
    </button>
</div>

