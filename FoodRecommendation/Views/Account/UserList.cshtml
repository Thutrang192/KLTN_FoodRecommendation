@using FoodRecommendation.Models.Entity
@using Newtonsoft.Json;
@using Microsoft.AspNetCore.Http;
@using FoodRecommendation.Constant;
@using System.Security.Claims
@model IEnumerable<FoodRecommendation.Models.Entity.Account>

@{
    ViewData["Title"] = "Danh sách người dùng";
}

@{
    Layout = "_Layout";
}


<link rel="stylesheet" href="~/css/userlist.css" asp-append-version="true" />


<div class="user-container">
        <!-- SEARCH -->
        <div class="d-flex justify-content-between align-items-center mb-4 mt-4">
                    <h2 class="mb-0">Danh sách người dùng (@ViewBag.TotalItems)</h2>
            <div class="search-ct mb-0">
                <input type="text" id="searchInput"
                        placeholder="Tìm theo tên, email hoặc tên đăng nhập..." />
            </div>
        </div>

        <!-- TABLE -->
        <div class="table-wrapper">
            <table class="user-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" /></th>
                        <th>Họ và tên</th>
                        <th>Email cá nhân</th>
                        <th>Tên đăng nhập</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>

                <tbody id="userTable">
                    @foreach (var item in Model)
                    {
                        <tr data-name="@item.FullName?.ToLower()"
                            data-email="@item.Email.ToLower()"
                            data-username="@item.Username.ToLower()">

                            <td><input type="checkbox" /></td>
                       
                            <td>
                                @item.FullName <br />

                                @if (item.IsActivated == false)
                                {
                                    <span class="badge-inactive">Không hoạt động</span>
                                }
                            </td>
                            <td>@item.Email</td>
                            <td>@item.Username</td>

                            <td class="action">
                                <a asp-controller="User" asp-action="Edit" asp-route-id="@item.UserId" class="btn-icon edit">
                                    <i class="fa fa-edit"></i>
                                </a>
    
  
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <div class="pagination">
            <a asp-action="UserList" asp-route-page="1">«</a>

            <a asp-action="UserList"
               asp-route-page="@(ViewBag.CurrentPage > 1 ? ViewBag.CurrentPage - 1 : 1)">
                ‹
            </a>

            <div class="page-info">
                Trang @(ViewBag.CurrentPage ?? 1) / @(ViewBag.TotalPages ?? 1)
            </div>

            <a asp-action="UserList"
               asp-route-page="@(ViewBag.CurrentPage < ViewBag.TotalPages ? ViewBag.CurrentPage + 1 : ViewBag.TotalPages)">
                ›
            </a>

            <a asp-action="UserList" asp-route-page="@ViewBag.TotalPages">»</a>
        </div>

    </div>


<script>
    document.getElementById("searchInput").addEventListener("keyup", function () {
        let keyword = this.value.toLowerCase();
        let rows = document.querySelectorAll("#userTable tr");

        rows.forEach(row => {
            let name = row.dataset.name || "";
            let email = row.dataset.email || "";
            let username = row.dataset.username || "";

            if (name.includes(keyword) || email.includes(keyword) || username.includes(keyword)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    });
</script>


    
