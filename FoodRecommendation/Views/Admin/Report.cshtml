@using FoodRecommendation.Models.Model;
@model IEnumerable<RecipeModel>

@{
    ViewData["Title"] = "Quản lý báo cáo món ăn";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-4">Món ăn bị báo cáo (@Model.Count())</h2>
        <form asp-action="Report" method="get" class="d-flex gap-2 mb-3">
            <select name="status" 
                    onchange="this.form.submit()" 
                    class="form-select" style="max-width: 170px;">
                <option value="pending" selected="@(Context.Request.Query["status"] == "pending" || string.IsNullOrEmpty(Context.Request.Query["status"]))">Chưa xử lý</option>
                <option value="processed" selected="@(Context.Request.Query["status"] == "processed")">Đã xử lý</option>
                <option value="all" selected="@(Context.Request.Query["status"] == "all")">Tất cả</option>
            </select>
        </form>
    </div>
    
    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Hình ảnh</th>
                        <th>Tiêu đề</th>
                        <th>Ngày tạo</th>
                        <th class="text-center">Số báo cáo</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                Không có món ăn nào bị báo cáo.
                            </td>
                        </tr>
                    }

                    @{ int i = 1;} 
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(i++)</td>
                            <td>
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/default-recipe.jpeg" : item.ImageUrl)"
                                     width="70" class="rounded shadow-sm">
                            </td>
                            <td class="fw-bold">@item.Title</td>
                            <td class="text-nowrap">@item.FormattedCreatedAt</td>
                            <td class="fw-bold text-center">@item.TotalReport</td>
                            <td class="text-center">
                                @if (item.Reports.All(x => x.StatusReport == "Processed"))
                                {
                                    <button class="btn btn-sm btn-secondary" disabled>
                                        <i class="bi bi-check-circle"></i> Đã xử lý
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-success"
                                            onclick="openProcessingModal(@item.RecipeId, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Title))')">
                                        <i class="bi bi-eye"></i> Xem báo cáo
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="processingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-shield-exclamation"></i> Chi tiết báo cáo vi phạm</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 id="modalRecipeTitle" class="text-dark mb-0"></h5>
                    <a id="btnViewRecipe" href="#" target="_blank" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-eye"></i> Xem món ăn
                    </a>
                </div>

                <div class="table-responsive" style="max-height: 300px;">
                    <table class="table table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Người báo cáo</th>
                                <th>Email</th>
                                <th>Nội dung</th>
                                <th>Thời gian</th>
                            </tr>
                        </thead>
                        <tbody id="reportTableBody"></tbody>
                    </table>
                </div>

                <div class="alert alert-light border mt-3 text-center">
                    <p class="mb-2 fw-bold">Chọn hành động xử lý:</p>
                    <div class="d-flex justify-content-center gap-2">
                        <button class="btn btn-warning" onclick="submitAction('hide')">
                            <i class="bi bi-eye-slash"></i> Ẩn món
                        </button>
                        <button class="btn btn-success" onclick="submitAction('safe')">
                            <i class="bi bi-shield-check"></i> An toàn (Giữ lại)
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lấy dữ liệu từ Model sang JS
        const recipesData = @Html.Raw(Json.Serialize(Model));
        let currentRecipeId = null;
        let processModal = null;

        function openProcessingModal(id, title) {
            currentRecipeId = id;
            const recipe = recipesData.find(r => r.recipeId === id || r.RecipeId === id);
            
            if (!recipe) return;

            document.getElementById('modalRecipeTitle').innerText = title;
            document.getElementById('btnViewRecipe').href = `/Home/Detail/${id}`;

            const tbody = document.getElementById('reportTableBody');

            const reportList = recipe.reports || recipe.Reports || [];

            tbody.innerHTML = reportList.map(r => `
                <tr>
                    <td><span class="fw-bold">${r.username}</span></td>
                    <td>${r.email}</td>
                    <td>${r.reason || r.Reason}</td>
                    <td>${new Date(r.createdAt || r.CreatedAt).toLocaleString('vi-VN')}</td>
                </tr>
            `).join('');

            processModal = new bootstrap.Modal(document.getElementById('processingModal'));
            processModal.show();
        }

        async function submitAction(type) {
            const confirmMsg = type === 'hide'
                ? "Món ăn sẽ bị ẩn và gửi thông báo vi phạm tới người báo cáo?"
                : "Xác nhận món ăn an toàn và gửi thông báo phản hồi?";

            if (!confirm(confirmMsg)) return;

            try {
                const response = await fetch('/Admin/HandleReportProcess', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        recipeId: currentRecipeId,
                        actionType: type
                    })
                });

                if (response.ok) {
                    alert("Đã xử lý và gửi thông báo thành công!");
                    location.reload();
                } else {
                    const errorData = await response.text();
                    console.error("Server Error:", errorData);
                    alert("Lỗi khi xử lý: " + response.status);
                }
            } catch (err) {
                alert("Không thể kết nối đến máy chủ.");
            }
        }
    </script>
}